# IMAP credentials
# Phase 1: Gmail app password (Gmail Settings → Security → App Passwords)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASSWORD=your-16-char-app-password

# Sync configuration
# Default sync duration (e.g. 7d, 5w, 3m, 2y). Overridden by CLI --since. Default: 1y.
# Set to 1d for fast local dev syncs.
# DEFAULT_SYNC_SINCE=1d

# Mailbox to sync (optional). If unset: Gmail → [Gmail]/All Mail, else INBOX.
# SYNC_MAILBOX=[Gmail]/All Mail

# Labels to exclude from sync, comma-separated (e.g. Trash,Spam). Case-insensitive. Default: Trash,Spam.
# SYNC_EXCLUDE_LABELS=Trash,Spam

# Google OAuth — for web UI login (Phase 1) and IMAP auth (Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web UI / MCP server
PORT=3000
AUTH_SECRET=change-me-to-a-random-string

# Data directory — where maildir, SQLite DB, and vectors are stored
DATA_DIR=./data

# Optional: OpenAI API key for semantic search embeddings
OPENAI_API_KEY=
