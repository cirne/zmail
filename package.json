{
  "name": "agentmail",
  "version": "0.1.0",
  "description": "Agent-first email system — sync, index, and search email for AI agents",
  "scripts": {
    "dev": "bun run src/index.ts",
    "sync": "bun run src/sync/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/agentmail",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "hono": "latest",
    "imapflow": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
