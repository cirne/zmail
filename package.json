{
  "name": "@cirne/zmail",
  "version": "0.1.0",
  "description": "Agent-first email system — sync, index, and search email for AI agents",
  "scripts": {
    "dev": "tsx src/index.ts",
    "zmail": "tsx src/index.ts --",
    "sync": "tsx src/sync/index.ts",
    "build": "tsc && tsc-alias && node scripts/post-build.js",
    "install-cli": "tsx scripts/install-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "type": "module",
  "engines": { "node": ">=20" },
  "bin": { "zmail": "dist/index.js" },
  "dependencies": {
    "@cedrugs/pdf-parse": "^1.0.0",
    "@lancedb/lancedb": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "better-sqlite3": "^12.6.2",
    "exceljs": "^4.4.0",
    "imapflow": "latest",
    "mailparser": "^3.9.3",
    "mammoth": "^1.11.0",
    "openai": "latest",
    "postal-mime": "^2.7.3",
    "search-query-parser": "^1.6.0",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/mailparser": "^3.4.6",
    "@types/turndown": "^5.0.6",
    "docx": "^9.6.0",
    "pdf-lib": "^1.17.1",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "latest",
    "vitest": "^3.2.4"
  }
}
