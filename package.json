{
  "name": "zmail",
  "version": "0.1.0",
  "description": "Agent-first email system — sync, index, and search email for AI agents",
  "scripts": {
    "dev": "bun run src/index.ts",
    "sync": "bun run src/sync/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/zmail",
    "install-cli": "bun run scripts/install-cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@lancedb/lancedb": "latest",
    "@modelcontextprotocol/sdk": "latest",
    "hono": "latest",
    "imapflow": "latest",
    "mailparser": "^3.9.3",
    "openai": "latest",
    "postal-mime": "^2.7.3",
    "search-query-parser": "^1.6.0",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mailparser": "^3.4.6",
    "@types/turndown": "^5.0.6",
    "typescript": "latest"
  }
}
